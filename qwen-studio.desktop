#!/usr/bin/env xdg-open
[Desktop Entry]
Name=Qwen Studio
Comment=Open-source Qwen AI desktop client with MCP support
Exec=env WEBKIT_DISABLE_COMPOSITING_MODE=1 WEBKIT_DISABLE_DMABUF_RENDERER=1 /opt/qwen-studio/qwen-studio
Icon=qwen-studio
Terminal=false
Type=Application
Categories=Development;Chat;Network;
StartupWMClass=qwen-studio
