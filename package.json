{
  "name": "qwen-studio",
  "version": "2.1.0",
  "type": "module",
  "description": "Open-source Qwen AI (Tongyi Qianwen) desktop client for Linux. Full MCP support, system tray, bundled runtimes. Alternative to official Windows/Mac-only Qwen Studio app.",
  "main": "./out/main/index.js",
  "author": "youssefvdel <youssefvdel@gmail.com>",
  "homepage": "https://chat.qwen.ai/",
  "repository": {
    "type": "git",
    "url": "https://github.com/youssefvdel/qwen-studio.git"
  },
  "scripts": {
    "start": "npm run copy-assets && tsc && electron-forge start",
    "package": "npm run copy-assets && tsc && electron-forge package",
    "make": "npm run copy-assets && tsc && electron-forge make",
    "make:deb": "npm run copy-assets && tsc && electron-forge make --targets=@electron-forge/maker-deb",
    "make:rpm": "npm run copy-assets && tsc && electron-forge make --targets=@electron-forge/maker-rpm",
    "make:all": "npm run copy-assets && tsc && electron-forge make",
    "build": "tsc && electron-builder --linux AppImage",
    "build:deb": "electron-builder --linux deb",
    "build:rpm": "electron-builder --linux rpm",
    "build:all": "electron-builder --linux",
    "copy-assets": "cp -r src/renderer/* out/renderer/ 2>/dev/null || mkdir -p out/renderer && cp -r src/renderer/* out/renderer/",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "postinstall": "node scripts/download-runtimes.js"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.13.1",
    "@types/node-fetch": "^2.6.13",
    "@types/uuid": "^10.0.0",
    "cors": "^2.8.5",
    "electron-settings": "^4.0.4",
    "electron-updater": "^6.3.9",
    "electron-window-state": "^5.0.3",
    "express": "^5.1.0",
    "i18next": "^25.1.2",
    "i18next-fs-backend": "^2.6.0",
    "node-fetch": "^2.7.0",
    "uuid": "^13.0.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.0",
    "@electron-forge/maker-deb": "^7.8.0",
    "@electron-forge/maker-rpm": "^7.8.0",
    "@electron-forge/maker-zip": "^7.8.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.0",
    "@electron-forge/plugin-fuses": "^7.8.0",
    "@electron/fuses": "^1.8.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^1.6.1",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0",
    "vitest": "^1.6.1"
  },
  "keywords": [
    "qwen",
    "qwen-ai",
    "qwen-studio",
    "linux",
    "ubuntu",
    "fedora",
    "arch",
    "electron",
    "mcp",
    "model-context-protocol",
    "ai-chat",
    "desktop-app",
    "appimage",
    "deb",
    "rpm",
    "alibaba-cloud"
  ],
  "license": "MIT",
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{js,json,md}": [
      "prettier --write"
    ]
  }
}
